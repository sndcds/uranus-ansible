server {
    listen 80;
    server_name {{ frontend_domain }};
{% if local_test_mode | default(false) | bool %}

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name {{ frontend_domain }};
    root /opt/uranus/frontend/dist;
    index index.html;

    ssl_certificate /etc/ssl/localcerts/{{ frontend_domain }}.crt;
    ssl_certificate_key /etc/ssl/localcerts/{{ frontend_domain }}.key;

    location / {
        try_files $uri $uri/ /index.html;
    }
{% else %}
    root /opt/uranus/frontend/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
{% endif %}
}
