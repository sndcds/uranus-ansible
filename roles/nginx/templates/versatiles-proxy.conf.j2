server {
    listen 80;
    server_name {{ versatiles_domain }};
{% if local_test_mode | default(false) | bool %}

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name {{ versatiles_domain }};

    ssl_certificate /etc/ssl/localcerts/{{ versatiles_domain }}.crt;
    ssl_certificate_key /etc/ssl/localcerts/{{ versatiles_domain }}.key;
{% endif %}

    location / {
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
        proxy_pass http://127.0.0.1:{{ versatiles_port }}/;
    }
}
